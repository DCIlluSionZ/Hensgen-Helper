# Copy this file to .env.local and put your Gemini API key in.
# .env.local is gitignored so the key stays off GitHub.
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: a second Gemini key (e.g. a free-tier key from a different
# Google account) used automatically if the primary one runs out of quota.
# Leave blank if you don't have a second key.
VITE_GEMINI_API_KEY_FALLBACK=
